<tb:TaskbarIcon x:Class="Vcheck_Listener.Views.TrayIcon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        IconSource="/Lib/Images/Bionote-favicon.ico"
        ToolTipText="VCheck Listener Running">

    <tb:TaskbarIcon.ContextMenu>
        <ContextMenu>
            <MenuItem Name="ShowConfig_Button" Header="Settings" Click="ShowConfig_Click"/>
            <MenuItem Name="ShowLog_Button" Header="Logs" Click="ShowLog_Click"/>
            <MenuItem Name="Exit_Button" Header="Exit" Click="Exit_Click"/>
        </ContextMenu>
    </tb:TaskbarIcon.ContextMenu>
</tb:TaskbarIcon>