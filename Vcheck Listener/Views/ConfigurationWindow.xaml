<Window x:Class="Vcheck_Listener.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vcheck_Listener.Views"
        mc:Ignorable="d" MinWidth="550" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Border BorderBrush="{DynamicResource Themes_FontColor}" BorderThickness="1" CornerRadius="5" Padding="5" Background="{DynamicResource Themes_PageBackground}">
        <Grid x:Name="ConfigurationsGrid" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" HorizontalAlignment="Stretch" MouseLeftButtonDown="TitleBar_MouseLeftButton" MouseLeftButtonUp="TitleBar_MouseLeftButton" Margin="0,0,0,10" Background="{DynamicResource Themes_PageBackground}">
                <TextBlock Text="Settings" HorizontalAlignment="Center" FontSize="20" Foreground="{DynamicResource Themes_FontColor}"/>
            </Border>

            <!--<Grid Grid.Row="0" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Button Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Right" Grid.Column="1" Click="Cancel_Click">
                    <Image Source="{DynamicResource Themes_CloseIcon}" Width="10"/>
                </Button>
            </Grid>-->

            <Grid Grid.Row="1" Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Listener IP" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="ListenerIP" Grid.Row="1" IsHitTestVisible="False"/>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Listener Port" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="ListenerPort" Grid.Row="1" IsHitTestVisible="False"/>
                </Grid>
            </Grid>

            <Border Grid.Row="2" BorderThickness="2" BorderBrush="{DynamicResource Themes_FontColor}" Height="1"></Border>

            <Grid Grid.Row="3" Margin="10" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Schedule Automation" Grid.Column="0" Foreground="{DynamicResource Themes_FontColor}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <!-- Toggle Switch -->
                <ToggleButton x:Name="ScheduleAutomationSwitch" Width="40" Height="15" IsChecked="False" Grid.Column="1" Click="SwitchButton_Click">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <!-- Background -->
                                            <Border x:Name="SwitchBackground"
                                            CornerRadius="8"
                                            Background="LightGray"
                                            BorderBrush="#CCC"
                                            BorderThickness="1">
                                                <TextBlock x:Name="SwitchText" Text="OFF" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="5" FontSize="9" FontWeight="Bold"/>
                                            </Border>

                                            <!-- Knob -->
                                            <Ellipse x:Name="SwitchKnob"
                                             Width="11" Height="11"
                                             Fill="White"
                                             Margin="2"
                                             HorizontalAlignment="Left"/>
                                        </Grid>

                                        <!-- Animation Triggers -->
                                        <ControlTemplate.Triggers>
                                            <!-- ON State -->
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="SwitchBackground" Property="Background" Value="#4CAF50"/>
                                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="SwitchText" Property="HorizontalAlignment" Value="Left"/>
                                                <Setter TargetName="SwitchText" Property="Text" Value="ON"/>
                                            </Trigger>

                                            <!-- Mouse Over -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SwitchBackground" Property="BorderBrush" Value="#888"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </Grid>

            <Grid Grid.Row="3" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Analyzer Type" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                <ComboBox VerticalAlignment="Center" Grid.Row="1" x:Name="AnalyzerType" MouseUp="ComboBox_MouseUp" SelectionChanged="AnalyzerType_SelectionChanged">
                    <ComboBoxItem Content="-- Select Analyzer Type--" Tag="Default" IsSelected="True"/>
                    <ComboBoxItem Content="C1" Tag="C1"/>
                    <ComboBoxItem Content="C10" Tag="C10"/>
                    <ComboBoxItem Content="H6" Tag="H6"/>
                    <ComboBoxItem Content="M10" Tag="M10"/>
                    <ComboBoxItem Content="U3" Tag="U3"/>
                    <ComboBoxItem Content="V200/V2400" Tag="V200/V2400"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="4" Margin="0,10,0,10" x:Name="AnalyzerGrid" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Analyzer IP" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="AnalyzerIP" Grid.Row="1"/>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Analyzer Port" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="AnalyzerPort" Grid.Row="1"/>
                </Grid>
            </Grid>

            <Border Grid.Row="5" BorderThickness="2" BorderBrush="{DynamicResource Themes_FontColor}" Height="1"></Border>
            
            <Grid Grid.Row="6" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Conversion Chart" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                <ComboBox VerticalAlignment="Center" Grid.Row="1" x:Name="ConversionChart" SelectionChanged="ConversionChart_SelectionChanged" MouseUp="ComboBox_MouseUp">
                    <ComboBoxItem Content="-- Select Conversion Chart --" Tag="Default" IsSelected="True"/>
                    <ComboBoxItem Content="Greywind" Tag="Greywind"/>
                    <ComboBoxItem Content="DRX - Taiwan" Tag="DRX - Taiwan"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="7" Margin="0,10,0,10" x:Name="PIMSGrid1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Grid Grid.Column="0" Margin="10,0,10,0" Name="ClinicIDGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Clinic ID" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="ClinicID" Grid.Row="1"/>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,10,0" x:Name="PIMSIPGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="PIMS IP" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="PIMSIP" Grid.Row="1"/>
                </Grid>

                <Grid Grid.Column="2" Margin="10,0,10,0" x:Name="PIMSPortGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="PIMS Port" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="PIMSPort" Grid.Row="1"/>
                </Grid>
            </Grid>

            <Grid Grid.Row="8" Margin="0,10,0,10" x:Name="PIMSGrid2" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="10,0,10,0" x:Name="PIMSUsernameGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="PIMS Username" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="PIMSUsername" Grid.Row="1"/>
                </Grid>

                <Grid Grid.Column="1" Margin="10,0,10,0" x:Name="PIMSPasswordGrid" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="PIMS Password" Grid.Row="0" Margin="0,0,0,10" Foreground="{DynamicResource Themes_FontColor}"/>
                    <TextBox x:Name="PIMSPassword" Grid.Row="1" Background="Transparent"  BorderBrush="{DynamicResource Themes_FontColor}" Foreground="{DynamicResource Themes_FontColor}" CaretBrush="{DynamicResource Themes_FontColor}"/>
                </Grid>
            </Grid>

            <Border Grid.Row="9" BorderThickness="2" BorderBrush="{DynamicResource Themes_FontColor}" Height="1"></Border>

            <Grid Grid.Row="10" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Cancel" Grid.Column="0" Style="{DynamicResource RoundButton}" BorderThickness="0" Foreground="{DynamicResource Themes_FontColor}" Background="Transparent" Margin="10" Click="Cancel_Click"/>
                <Button Content="Save" Grid.Column="1" Style="{DynamicResource RoundButton}" Background="#1e76fb" Foreground="White" BorderThickness="0" Margin="10" Click="Save_Click"/>
            </Grid>

        </Grid>
    </Border>
    
</Window>
