<Page x:Class="VCheckViewer.Views.Pages.Setting.Interface.ConfigurationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VCheckViewer.Views.Pages.Setting.Interface"
      xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConfigurationPage">

    <Page.Resources>
        <!-- Custom RadioButton Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <!-- Outer Border -->
                            <Border x:Name="OuterBorder"
                                    Width="16" Height="16"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource Themes_SearchFieldFontColor}"
                                    Background="White"
                                    Margin="0,0,5,0">
                                <!-- Inner Circle -->
                                <Ellipse x:Name="InnerCircle"
                                         Fill="Transparent"
                                         Width="8" Height="8"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <!-- Change border color when checked -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="Blue"/>
                                <Setter TargetName="InnerCircle" Property="Fill" Value="Blue"/>
                            </Trigger>
                            <!-- Change border color on hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="Blue"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="0, 10, 0, 10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!--<Border Grid.Column="1" Grid.ColumnSpan="2" Height="45" CornerRadius="7" BorderThickness="1" BorderBrush="Black" Background="Black" MaxWidth="600">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" MinWidth="90"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto" MinWidth="90"/>
                    <ColumnDefinition Width="auto" MinWidth="90"/>
                    <ColumnDefinition Width="auto" MinWidth="90"/>
                    <ColumnDefinition Width="auto" MinWidth="90"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="2">
                    <Button Content="{Binding Path=Setting_Label_User, Source={StaticResource Resources}}" Name="btnUser" Background="Black" BorderThickness="0" Foreground="White" HorizontalAlignment="Stretch" Style="{DynamicResource RoundButton}" Click="btnUser_Click"></Button>
                </Border>
                <Border Grid.Column="1" Margin="2">
                    <Button Content="{Binding Path=Setting_Label_LanguageCountry, Source={StaticResource Resources}}" Name="btnLanguage" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="btnLanguage_Click"></Button>
                </Border>
                <Border Grid.Column="2" Margin="2">
                    <Button Content="PMS/LIS/HIS" Background="{DynamicResource Themes_ButtonColor}" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Style="{DynamicResource RoundButton}"></Button>
                </Border>
                <Border Grid.Column="3" Margin="2">
                    <Button Content="{Binding Path=Setting_Label_Device, Source={StaticResource Resources}}" Name="btnDevice" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="btnDevice_Click"></Button>
                </Border>
                <Border Grid.Column="4" Margin="2">
                    <Button Content="{Binding Path=Report_Label_Report, Source={StaticResource Resources}}" Name="btnReport" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="btnReport_Click"></Button>
                </Border>
                <Border Grid.Column="5" Margin="2">
                    <Button Content="{Binding Path=ClinicInfo_Label_ClinicInfo, Source={StaticResource Resources}}" Name="btnClinic" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="ClinicInfoPage"></Button>
                </Border>
            </Grid>
        </Border>-->
        <Border Grid.Column="1" Grid.ColumnSpan="2" Height="45" CornerRadius="7" BorderThickness="1" BorderBrush="Black" Background="Black" MaxWidth="600">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Margin="2">
                    <Button Content="Information" Name="btnInfo" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="btnInfo_Click"></Button>
                </Border>
                <Border Grid.Column="1" Margin="2">
                    <Button Content="PMS/LIS/HIS" Background="{DynamicResource Themes_ButtonColor}" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Style="{DynamicResource RoundButton}"></Button>
                </Border>
                <Border Grid.Column="2" Margin="2">
                    <Button Content="{Binding Path=Setting_Label_Device, Source={StaticResource Resources}}" Name="btnDevice" Foreground="White" HorizontalAlignment="Stretch" BorderThickness="0" Background="Black" Style="{DynamicResource RoundButton}" Click="btnDevice_Click"></Button>
                </Border>
            </Grid>
        </Border>
        <Button Grid.Column="3" Content="Download Software" Foreground="{DynamicResource Themes_ButtonFontColor}" HorizontalAlignment="Left" BorderBrush="{DynamicResource Themes_ButtonColor}" Background="{DynamicResource Themes_ButtonColor}" Style="{DynamicResource RoundButton}" Grid.Row="0" Width="130" Height="40" Click="DownloadButton_Clicked"/>
        <Border Name="borderPMSSelection" Grid.Column="1" Grid.Row="2" BorderBrush="Transparent" BorderThickness="0" Margin="30,30,30,0">
            <Border BorderThickness="1" BorderBrush="{DynamicResource Themes_InterfaceFrameBackground}" Padding="10" CornerRadius="7" Background="{DynamicResource Themes_InterfaceFrameBackground}">
                <Grid x:Name="gridPMSSelection">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <RadioButton Name="Greywind" Grid.Row="0" Foreground="{DynamicResource Themes_FontColor}" Content="Greywind PMS" Margin="10, 30, 0, 10" Checked="RadioButton_Checked"/>
                    <RadioButton Name="Other" Grid.Row="1" Foreground="{DynamicResource Themes_FontColor}" Content="Other PMS" Margin="10, 10, 0, 10" Checked="RadioButton_Checked"/>
                    <RadioButton Name="None" Grid.Row="2" Foreground="{DynamicResource Themes_FontColor}" Content="PC Mode" Margin="10, 10, 0, 10" Checked="RadioButton_Checked"/>

                </Grid>
            </Border>
        </Border>
        <Border Name="borderConfiguration" Grid.Column="2" Grid.Row="2" BorderBrush="Transparent" BorderThickness="0" Margin="30,30,30,0">
            <Border BorderThickness="1" BorderBrush="{DynamicResource Themes_InterfaceFrameBackground}" Padding="10" CornerRadius="7" Background="{DynamicResource Themes_InterfaceFrameBackground}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="borderIPLabel" Text="{Binding Path=Configuration_Label_PMS_LIS_HIS, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_FontColor}" Grid.Row="1" VerticalAlignment="Bottom" FontFamily="Noto Sans" FontSize="13" FontWeight="Bold" Margin="10, 30, 0, 10"></TextBlock>
                    <Border Name="borderIP" Grid.Row="2" Background="White" Padding="5" BorderBrush="Black" BorderThickness="1" CornerRadius="7">
                        <TextBox x:Name="txtIP" KeyUp="FieldsVal_KeyUp" FontFamily="Noto Sans" Background="White"/>
                    </Border>

                    <TextBlock x:Name="borderPortNoLabel" Text="{Binding Path=Configuration_Label_PMS_LIS_HIS_PortNo, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_FontColor}" Grid.Row="3" VerticalAlignment="Bottom" FontFamily="Noto Sans" FontSize="13" FontWeight="Bold" Margin="10, 10, 0, 10"></TextBlock>
                    <Border Name="borderPortNo" Grid.Row="4" Background="White" Padding="5" BorderBrush="Black" BorderThickness="1" CornerRadius="7">
                        <TextBox x:Name="txtPortNo" VerticalAlignment="Center" BorderThickness="0" PreviewTextInput="NumberValidationOnly" MaxLength="4" KeyUp="FieldsVal_KeyUp" />
                    </Border>

                    <TextBlock Name="ClinicPhoneNumLabel" Text="{Binding Path=ClinicInfo_Label_ClinicPhoneNumber, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_FontColor}" Grid.Row="5" VerticalAlignment="Bottom" FontFamily="Noto Sans" FontSize="13" FontWeight="Bold" Margin="10, 10, 0, 10" Visibility="Collapsed"></TextBlock>
                    <Border Name="borderClinicPhoneNum" Grid.Row="6" Background="White" Padding="5" BorderBrush="Black" BorderThickness="1" CornerRadius="7" Visibility="Collapsed">
                        <TextBox x:Name="txtClinicPhoneNum" VerticalAlignment="Center" BorderThickness="0" IsEnabled="False"/>
                    </Border>

                    <!--<Button x:Name="btnConnect" Grid.Row="7" Content="{Binding Path=ClinicInfo_Button_Connect, Source={StaticResource Resources}}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Foreground="White" Background="#0ed145" Margin="0,10,0,0" Visibility="Collapsed" Click="btnConnect_Click" IsEnabled="False"/>-->
                    

                    <TextBlock Name="UsernameLabel" Text="{Binding Path=Configuration_Label_UsernameClientID, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_FontColor}" Grid.Row="5" VerticalAlignment="Bottom" FontFamily="Noto Sans" FontSize="13" FontWeight="Bold" Margin="10, 10, 0, 10"></TextBlock>
                    <Border Name="borderUsername" Grid.Row="6" Background="White" Padding="5" BorderBrush="Black" BorderThickness="1" CornerRadius="7">
                        <TextBox x:Name="txtUsername" VerticalAlignment="Center" BorderThickness="0" KeyUp="FieldsVal_KeyUp" />
                    </Border>

                    <TextBlock Name="PasswordLabel" Text="{Binding Path=Configuration_Label_UsernameClientSecret, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_FontColor}" Grid.Row="7" VerticalAlignment="Bottom" FontFamily="Noto Sans" FontSize="13" FontWeight="Bold" Margin="10, 10, 0, 10"></TextBlock>
                    <Border Name="borderPassword" Grid.Row="8" Background="White" Padding="5" BorderBrush="Black" BorderThickness="1" CornerRadius="7">
                        <PasswordBox x:Name="txtPassword" VerticalAlignment="Center" BorderThickness="0"  KeyUp="FieldsVal_KeyUp" />
                    </Border>

                    <Button x:Name="btnConnect" Grid.Row="9" Content="{Binding Path=Maintenance_Label_NotConnected, Source={StaticResource Resources}}" Tag="Not Connected" VerticalAlignment="Bottom" HorizontalAlignment="Right" Foreground="White" Background="Gray" Margin="0,10,0,0" IsHitTestVisible="False" IsEnabled="True"/>

                    <TextBlock x:Name="NoneLabel" Text="" Grid.Row="0"/>

                </Grid>
            </Border>
        </Border>
        <!--<Button x:Name="btnUpdate" Grid.Column="3" Grid.Row="2" Content="{Binding Path=Configuration_Label_Button_Update, Source={StaticResource Resources}}" VerticalAlignment="Bottom" Foreground="White"
            Background="{DynamicResource Themes_ButtonColor}" BorderBrush="{DynamicResource Themes_ButtonColor}" Margin="0" Style="{DynamicResource RoundButton}" 
            IsEnabled="False" Click="btnUpdate_Click"/>-->
        <Button x:Name="btnUpdate" Grid.Column="3" Grid.Row="2" Content="{Binding Path=ClinicInfo_Button_Connect, Source={StaticResource Resources}}" VerticalAlignment="Bottom" Foreground="White"
            Background="{DynamicResource Themes_ButtonColor}" BorderBrush="{DynamicResource Themes_ButtonColor}" Margin="0" Style="{DynamicResource RoundButton}" 
            IsEnabled="False" Click="btnUpdate_Click"/>
    </Grid>
</Page>
