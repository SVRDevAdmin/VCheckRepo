<Page x:Class="VCheckViewer.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VCheckViewer.Views.Pages"
      mc:Ignorable="d" 
      Title="DashboardPage">

    <Grid>
        <TextBlock TextWrapping="Wrap" Text="{Binding Path=Dashboard_Title_PageTitle, Source={StaticResource Resources}}" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="collapsed"/>
        <DockPanel Visibility="Visible">
            <DockPanel DockPanel.Dock="Top" Name="VersionUpdate">
                <Border CornerRadius="7" BorderThickness="1" BorderBrush="{DynamicResource Themes_DashboardFrameBackground}" Background="{DynamicResource Themes_DashboardFrameBackground}" Height="300" HorizontalAlignment="Stretch" Margin="10, 0, 10, 0">
                    <!-- Height="200" -->
                    <DockPanel VerticalAlignment="Stretch">
                        <StackPanel Orientation="Vertical" Margin="40,20,0,20">
                            <TextBlock x:Name="updateMessage" TextWrapping="WrapWithOverflow" FontSize="23" FontWeight="Bold" Width="550" Margin="0,0,0,10" Grid.Row="0" LineHeight="30" Foreground="{DynamicResource Themes_FontColor}"/>
                            <Button Content="{Binding Path=General_Label_Download, Source={StaticResource Resources}}" Foreground="{DynamicResource Themes_ButtonFontColor}" HorizontalAlignment="Left" BorderBrush="{DynamicResource Themes_ButtonColor}" Background="{DynamicResource Themes_ButtonColor}" Style="{DynamicResource RoundButton}" Grid.Row="1" Width="130" Height="40" Margin="0,10,0,0" Click="DownloadButton_Clicked"/>                               
                        </StackPanel>
                        <Image Source="../../../Content/Images/mask_group_1.png" Height="240" HorizontalAlignment="Right" Margin="0,-37,40,0"/>


                    </DockPanel>
                </Border>
            </DockPanel>
            <DockPanel DockPanel.Dock="Bottom">
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,10,0">
                    <StackPanel x:Name="responsiveView" Orientation="Vertical">
                        <Grid Margin="0, 10, 0, 10">
                            <TextBlock FontSize="50" TextAlignment="Center" Foreground="{DynamicResource Themes_FontColor}" Text="{Binding Path=Dashboard_Label_Loading, Source={StaticResource Resources}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </DockPanel>
    </Grid>
</Page>

