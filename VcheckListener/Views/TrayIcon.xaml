<tb:TaskbarIcon x:Class="VCheckListener.Views.TrayIcon"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        IconSource="/Bionote-favicon.ico"
        ToolTipText="Socket Listener Running">

    <tb:TaskbarIcon.ContextMenu>
        <ContextMenu>
            <MenuItem Name="ShowLog_Button" Header="Show Log" Click="ShowLog_Click"/>
            <MenuItem Name="Exit_Button" Header="Exit" Click="Exit_Click"/>
        </ContextMenu>
    </tb:TaskbarIcon.ContextMenu>
</tb:TaskbarIcon>
